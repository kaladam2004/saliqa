# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=wms
DB_PASSWORD=wms

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-secret-before-deploying-to-production

# ── Super Admin (created on first start) ─────────────────────────────────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=Admin@1234

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# For Docker Compose deployment: http://localhost
# For custom domain: https://wms.example.com
CORS_ORIGINS=http://localhost
